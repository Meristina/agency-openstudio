# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Node / frontend (app/studio) ──────────────────────────────────────────
**/node_modules/
app/studio/dist/
*.tsbuildinfo
*.local

# ── Local AI models & runtimes (never commit weights/binaries) ────────────
app/models/
app/llm-models/
app/speech-models/
app/tts-models/
app/openvino-models/
app/backend/
app/tts-runtime/
app/tools/

# ── Generated mission/run artifacts ───────────────────────────────────────
app/outputs/
app/cache/
missions/
chat-history/
transcriptions/

# ── Wave 2 — locally generated multimodal assets (images / audio) ─────────
# Downloaded model weights live in the OS cache (~/.cache/agency-studio,
# ~/.cache/huggingface), never in the repo. Generated outputs land here.
studio_assets/

# ── Wave 4/6 — local RAG / knowledge-graph / visual stores (rag.data_dir) ──
# SQLite corpora written when the studio is run with --path inside the repo
# (localdocs-*.db, visual-*.db, knowledge.db, mcp.json). Local user data — never committed.
.agency-studio/

# ── Partial downloads & archives ──────────────────────────────────────────
*.part
*.tmp
*.swp
*.zip
*.tar.gz
*.tar.xz

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
.env*

# ── OS / editor ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# Guard/healthcheck gate runtime markers (per-checkout review state)
.claude/.guard-state
.claude/.healthcheck-state
.claude/.ultra-state
.claude/.ultra-armed
